{
  "expo": {
    "name": "scripture",
    "description": "A scripture memorization and quiz app for practicing Bible verses on web and mobile.",
    "slug": "scripture",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "scripture",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "name": "Scripture",
      "shortName": "Scripture",
      "description": "Memorize and quiz Bible verses in a clean progressive web app.",
      "lang": "en",
      "scope": "/",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "themeColor": "#E6F4FE"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
